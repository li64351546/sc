   "source": [
    "import time\n",
    "import hashlib\n",
    "import random\n",
    "\n",
    "# 生成当前时间（精确到秒）\n",
    "current_time = time.strftime(\"%Y%m%d_%H%M%S\")\n",
    "\n",
    "# 生成8位随机哈希\n",
    "random_seed = str(random.random()).encode()\n",
    "hash_str = hashlib.md5(random_seed).hexdigest()[:8]\n",
    "\n",
    "# 拼接最终结果\n",
    "result = f\"{current_time}_{hash_str}\"\n",
    "\n",
    "print(result)"
   ]
  }
 ],
